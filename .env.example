# === Claves necesarias ===

# Token del bot de Telegram (te lo da @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRstuVWXyz

# API key de Groq (para transcribir audios con Whisper) -> https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# API key de Anthropic (para el cerebro del bot, Claude) -> https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# === Configuracion opcional (podes dejarla asi) ===

# Puerto del servidor web (API + Mini App)
PORT=3000

# URL publica HTTPS donde queda servida la Mini App (para el boton de menu).
# Ej: https://miapp.midominio.com   (dejar vacio en desarrollo)
WEBAPP_URL=

# Zona horaria para fechas relativas ("manana", "el viernes")
TZ=America/Argentina/Buenos_Aires

# Ruta del archivo de base de datos SQLite
DB_PATH=./data/asistente.db

# Admin(s) del bot: tu ID de Telegram (separá con coma si son varios).
# Los admin pueden dar de alta/baja clientes con /autorizar, /baja y /clientes.
# Para saber tu ID, escribile /id al bot.
ADMIN_IDS=

# IDs autorizados fijos por env (opcional, ademas de los clientes cargados por comando).
# Normalmente dejalo vacio y gestionás los clientes con /autorizar.
# Si NO hay admins, ni IDs aca, ni clientes cargados => el bot es ABIERTO.
ALLOWED_USER_IDS=

# Modelo de Claude. Por defecto Sonnet (confiable ejecutando acciones).
# Para ahorrar podes probar Haiku, pero a veces no guarda: claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# Tope de mensajes por dia por usuario (control de costos). 0 o vacio = sin limite.
# Recomendado si vas a tener clientes (ej: 50).
MAX_MSGS_DIA=

# Resumen automatico: expresion cron. Default lunes 9hs. "off" lo desactiva.
RESUMEN_CRON=0 9 * * 1

# Backups automaticos (envia la base a los ADMIN_IDS): cron. Default domingo 3am. "off" desactiva.
BACKUP_CRON=0 3 * * 0

# === Integración con Gestumio (CRM) ===
# URL base de tu Gestumio (para que el bot cargue gastos/cobros/clientes por vos).
GESTUMIO_API_URL=https://app.gestumio.com
